# ── LLM Provider ─────────────────────────────────────────────────────────
# Default: claude (uses ANTHROPIC_API_KEY). Set to deepseek for DeepSeek,
# or openrouter to reach DeepSeek (and ~100 other models) with only an
# OPENROUTER_API_KEY.
MODEL_PROVIDER=deepseek

# DeepSeek API key (from platform.deepseek.com)
DEEPSEEK_API_KEY=sk-...

# Model name for cheap stages (profile, company, problem, outreach)
# deepseek-chat is fast and cheap. deepseek-reasoner is slower but better.
DEEPSEEK_MODEL=deepseek-chat

# Claude API key (from console.anthropic.com) — needed if MODEL_PROVIDER=claude
ANTHROPIC_API_KEY=sk-ant-...

# Alternative: run every agent through OpenRouter (no DeepSeek key needed).
# OPENROUTER_MODEL is the OpenRouter slug used by the agents;
# UPSEARCH_CHEAP_MODEL_PROVIDER/UPSEARCH_CHEAP_MODEL keep the model router's
# cheap route consistent with that choice.
# MODEL_PROVIDER=openrouter
# OPENROUTER_MODEL=deepseek/deepseek-chat
# UPSEARCH_CHEAP_MODEL_PROVIDER=openrouter
# UPSEARCH_CHEAP_MODEL=deepseek/deepseek-chat


# ── Strong Model (judgment stages: technical note, QA) ────────────────────
# QA/verification routes here. When this is unset the router falls back to the
# cheap model and QA runs in degraded mode (it will not claim strong-model
# verification). Default below: GPT via OpenRouter, which works with only an
# OPENROUTER_API_KEY (no direct OpenAI or DeepSeek key required).
UPSEARCH_STRONG_MODEL_PROVIDER=openrouter
UPSEARCH_STRONG_MODEL=openai/gpt-5
# Tip: use the auto-latest alias to always get OpenAI's newest flagship:
# UPSEARCH_STRONG_MODEL=~openai/gpt-latest

# Alternative: DeepSeek's reasoning model directly (requires DEEPSEEK_API_KEY).
# ~10x cheaper than Claude Opus at similar quality for these tasks.
# UPSEARCH_STRONG_MODEL_PROVIDER=deepseek
# UPSEARCH_STRONG_MODEL=deepseek-reasoner

# Alternative: use Claude for best QA (highest cost, most thorough).
# Requires ANTHROPIC_API_KEY to be set above.
# UPSEARCH_STRONG_MODEL_PROVIDER=claude
# UPSEARCH_STRONG_MODEL=claude-opus-4-8

# Alternative: use DeepSeek R1 via OpenRouter (requires OPENROUTER_API_KEY).
# UPSEARCH_STRONG_MODEL_PROVIDER=openrouter
# UPSEARCH_STRONG_MODEL=deepseek/deepseek-r1

# Alternative: use Gemini via OpenRouter (requires OPENROUTER_API_KEY)
# Note: Gemini tends to be too lenient at verification — passes weak packets.
# UPSEARCH_STRONG_MODEL_PROVIDER=openrouter
# UPSEARCH_STRONG_MODEL=google/gemini-2.5-pro-preview-05-06


# ── People Discovery ──────────────────────────────────────────────────────
# GitHub token with `read:org` scope. Without this, unauthenticated rate limit
# is 60 req/hr (exhausted in ~20 minutes of testing). With token: 5000 req/hr.
# The people agent uses this to find real people with real GitHub profiles.
# Create at: https://github.com/settings/tokens (no write permissions needed)
GITHUB_TOKEN=


# ── External APIs (optional) ──────────────────────────────────────────────
# OpenRouter key — gateway to ~100 models including Gemini, Sonnet, Llama
# Create at: https://openrouter.ai/keys
OPENROUTER_API_KEY=sk-or-v1-...

# W&B key — for optional experiment logging (Quick Search pipeline)
# Create at: https://wandb.ai/authorize
WANDB_API_KEY=...


# ── Application Config ────────────────────────────────────────────────────
# Where tracking events are stored locally
UPSEARCH_TRACKING_DIR=.upsearch/runs

# Set to 1 in production to refuse startup when model config problems exist
# (missing agent key, unconfigured strong QA model, missing GITHUB_TOKEN).
# Unset by default so local dev and tests can run without keys.
# UPSEARCH_REQUIRE_MODELS=1
